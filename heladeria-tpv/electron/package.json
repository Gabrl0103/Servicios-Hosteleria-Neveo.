{
  "name": "heladeria-tpv-desktop",
  "version": "1.0.0",
  "description": "Aplicacion de escritorio para el TPV de la heladeria",
  "main": "main.js",
  "author": "Heladeria",
  "scripts": {
    "start": "electron .",
    "prepare-resources": "node prepare-resources.js",
    "dist": "npm run prepare-resources && electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.heladeria.tpv",
    "productName": "Heladeria TPV",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/backend/heladeria-tpv.jar",
        "to": "backend/heladeria-tpv.jar"
      },
      {
        "from": "resources/frontend",
        "to": "frontend"
      },
      {
        "from": "jre",
        "to": "jre"
      }
    ]
  }
}
